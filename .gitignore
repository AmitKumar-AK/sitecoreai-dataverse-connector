## A streamlined .gitignore for modern .NET projects
## including temporary files, build results, and
## files generated by popular .NET tools. If you are
## developing with Visual Studio, the VS .gitignore
## https://github.com/github/gitignore/blob/main/VisualStudio.gitignore
## has more thorough IDE-specific entries.
##
## Get latest from https://github.com/github/gitignore/blob/main/Dotnet.gitignore

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg

# dotenv environment variables file
.env

# Others
~$*
*~
CodeCoverage/

# MSBuild Binary and Structured Log
*.binlog

## ===== CRITICAL SECURITY - NEVER COMMIT =====
# Certificates and private keys (IMPORTANT FOR THIS PROJECT!)
*.pfx
*.cer
*.crt
*.key
*.pem
*.p12
certificate-info.json

# Connection strings and secrets
appsettings.Development.json
appsettings.*.json
!appsettings.json
*.secrets.json
secrets.json
local.settings.json
local.settings.*.json

# Environment variables
.env.*
!.env.example

# Azure credentials
azureauth.json
*.azureauth

## ===== Visual Studio =====
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
*.code-workspace

# ReSharper
_ReSharper*/
*.DotSettings.user

## ===== Azure Functions =====
# Azure Functions build output
.azurefunctions/
__blobstorage__/
__queuestorage__/
__azurite_db*__.json

# Azure publish profiles
PublishProfiles/
*.pubxml
*.publishsettings

## ===== Test Results =====
*.trx
*.coverage
*.coveragexml
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

## ===== NuGet =====
packages/
!**/packages/build/
*.nuget.props
*.nuget.targets

## ===== Backup Files =====
*.bak
*.tmp
*.temp
*.log
*.tlog
MigrationBackup/
UpgradeLog*.htm
UpgradeLog*.XML

## ===== Windows / macOS =====
Thumbs.db
.DS_Store
Desktop.ini
$RECYCLE.BIN/

## ===== JetBrains Rider =====
.idea/
*.sln.iml

## ===== Node.js (if adding front-end) =====
node_modules/
npm-debug.log*
yarn-debug.log*
package-lock.json

## ===== Project-Specific =====
# PowerShell script outputs (keep .ps1 scripts)
# Downloaded schema files
*-schema.json

# Custom build/publish outputs
publish/
artifacts/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml
